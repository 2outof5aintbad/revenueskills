# Vercel KV — copy real values from: vercel env pull .env.local
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Admin dashboard password — set this in Vercel project settings too
ADMIN_SECRET=your-secret-password-here

# Magic link auth
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SESSION_SECRET=a-long-random-string-at-least-32-chars
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
